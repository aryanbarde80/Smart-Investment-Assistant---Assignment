# Smart Investment Assistant — environment variables
# Copy this file to .env and fill in your values.
# All variables are optional; defaults work for local development.

# ── Storage ────────────────────────────────────────────────────────────────────
SIA_MAX_UPLOAD_MB=25
SIA_STORAGE_DIR=data
SIA_UPLOAD_DIR=uploads
SIA_EXTRACTED_ASSETS_DIR=extracted_assets

# ── LLM (optional) ─────────────────────────────────────────────────────────────
# Set this to enable DeepSeek-powered answer synthesis.
# Without it the system falls back to keyword-retrieval answers.
# Get your key at: https://platform.deepseek.com/api_keys
SIA_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
